{
  "name": "errorcore",
  "version": "0.1.1",
  "description": "Lightweight error monitoring SDK for Node.js — captures errors with full I/O context, local variables, and request replay data",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "error",
    "monitoring",
    "error-tracking",
    "debugging",
    "observability",
    "node"
  ],
  "bin": {
    "errorcore": "bin/errorcore.js"
  },
  "files": [
    "dist",
    "bin",
    "config-template"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/errorcoredev/errorcore.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "source-map-js": "1.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "hono": ">=4",
    "@hono/node-server": ">=1",
    "ioredis": ">=4",
    "mongodb": ">=5",
    "mysql2": ">=2",
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "@hono/node-server": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
